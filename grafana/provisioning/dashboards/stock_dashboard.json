        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stock-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  event_timestamp AS \"time\",\n  symbol AS metric,\n  price::double precision AS value\nFROM staging.stg_stock_prices\nWHERE $__timeFilter(event_timestamp)\nORDER BY 1, 2;",
          "refId": "A"
        }
      ],
      "title": "Live Price Line Chart",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "stock-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "direction"
          },
          {
            "desc": false,
            "displayName": "rank"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stock-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  direction,\n  rank,\n  symbol,\n  latest_price,\n  baseline_price,\n  price_change,\n  percent_change,\n  latest_timestamp\nFROM mart.top_gainers_losers\nORDER BY direction, rank;",
          "refId": "A"
        }
      ],
      "title": "Top Gainers & Losers Table",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "stock-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "hidden",
          "showLegend": false
        },
        "orientation": "vertical",
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stock-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  symbol,\n  sum(CASE WHEN is_volume_spike THEN 1 ELSE 0 END)::double precision AS spike_count\nFROM mart.volume_spikes\nWHERE $__timeFilter(event_timestamp)\nGROUP BY symbol\nORDER BY spike_count DESC, symbol;",
          "refId": "A"
        }
      ],
      "title": "Volume Spike Bar Chart",
      "type": "barchart"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "stock-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 6,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stock-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  event_timestamp AS \"time\",\n  'Actual Price' AS metric,\n  actual_price::double precision AS value\nFROM mart.moving_average\nWHERE symbol = '${symbol}'\n  AND $__timeFilter(event_timestamp)\nORDER BY 1;",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "stock-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  event_timestamp AS \"time\",\n  'Moving Average 5m' AS metric,\n  moving_average_5m::double precision AS value\nFROM mart.moving_average\nWHERE symbol = '${symbol}'\n  AND $__timeFilter(event_timestamp)\nORDER BY 1;",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "stock-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  event_timestamp AS \"time\",\n  'Moving Average 15m' AS metric,\n  moving_average_15m::double precision AS value\nFROM mart.moving_average\nWHERE symbol = '${symbol}'\n  AND $__timeFilter(event_timestamp)\nORDER BY 1;",
          "refId": "C"
        }
      ],
      "title": "Moving Average vs Actual Price",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
