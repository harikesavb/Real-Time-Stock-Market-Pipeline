    {
      "datasource": {
        "type": "postgres",
        "uid": "stock-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
